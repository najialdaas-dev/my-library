generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== MODELS ====================

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  description String?
  color     String   @default("#3B82F6")
  icon      String   @default("📚")
  
  books     Book[]
  tutorials Tutorial[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String?
  coverImage  String?
  
  // File info
  fileUrl     String
  fileName    String
  fileSize    Int
  
  // Relations
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  author      String?
  difficulty  String   @default("Intermediate")
  language    String   @default("Arabic")
  tags        String[]
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  
  downloadCount Int    @default(0)
  viewCount     Int    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([categoryId])
  @@index([slug])
}

model Tutorial {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String
  thumbnail   String?
  
  // Video
  videoUrl    String?
  videoId     String?
  
  // Relations
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  author      String?
  difficulty  String   @default("Intermediate")
  estimatedTime Int?
  tags        String[]
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  
  viewCount   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([categoryId])
  @@index([slug])
}

model View {
  id        String   @id @default(cuid())
  resourceId String
  resourceType String // "book" or "tutorial"
  viewedAt  DateTime @default(now())
  duration  Int?
  
  @@index([resourceId])
  @@index([viewedAt])
}

model Download {
  id        String   @id @default(cuid())
  resourceId String
  resourceType String
  downloadedAt DateTime @default(now())
  
  @@index([resourceId])
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @unique
  
  totalVisits Int    @default(0)
  totalDownloads Int @default(0)
  
  topBooks  Json?
  topTutorials Json?
  
  createdAt DateTime @default(now())
}
